{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/style.css",
      "headers": { "Content-Type": "text/css" },
      "dest": "public/style.css"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
